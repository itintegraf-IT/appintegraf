# Databáze – MySQL/MariaDB (AMPPS)
# Formát: mysql://user:password@host:port/database
DATABASE_URL="mysql://root:mysql@localhost:3306/appintegraf"

# Volitelně: migrace Plánování z igvyroba (npm run migrate:idvyroba / migrate:planovani)
# SOURCE_DATABASE_URL="mysql://root:mysql@localhost:3306/igvyroba"

# NextAuth – PRODUKCE: obě proměnné jsou povinné!
# Vygenerujte AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=""

# Kanonická URL aplikace (produkce: https://appintegraf.integraf.cz)
# Bez tohoto může přihlášení na HTTPS/proxy selhat; e-mailové odkazy v kalendáři ji také potřebují
AUTH_URL=""
# Volitelná alternativa k AUTH_URL pro absolutní odkazy (např. e-maily), pokud AUTH_URL nechcete duplikovat
# APP_URL=""

# Volitelně: denní úloha upozornění na končící smlouvy (POST /api/cron/contracts-expiry)
# CRON_SECRET="náhodný-dlouhý-řetězec"

# --- Vytěžení návrhu smlouvy z PDF (nová smlouva → „Návrh z PDF“) ---
# Výchozí: lokální Ollama (zdarma): https://ollama.com — např. ollama pull llama3.2
# OLLAMA_BASE_URL="http://127.0.0.1:11434"
# OLLAMA_MODEL="llama3.2"
# Místo Ollama lze použít OpenAI-kompatibilní endpoint (Groq, OpenRouter, Azure…):
# CONTRACT_EXTRACT_OPENAI_COMPAT_URL="https://api.example.com/v1/chat/completions"
# CONTRACT_EXTRACT_OPENAI_COMPAT_KEY=""
# CONTRACT_EXTRACT_OPENAI_COMPAT_MODEL="gpt-4o-mini"
# Vypnutí funkce na serveru: CONTRACT_EXTRACT_DISABLED=1
