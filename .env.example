# Databáze – MySQL/MariaDB (AMPPS)
# Formát: mysql://user:password@host:port/database
DATABASE_URL="mysql://root:mysql@localhost:3306/appintegraf"

# Volitelně: migrace Plánování z igvyroba (npm run migrate:idvyroba / migrate:planovani)
# SOURCE_DATABASE_URL="mysql://root:mysql@localhost:3306/igvyroba"

# NextAuth – PRODUKCE: obě proměnné jsou povinné!
# Vygenerujte AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=""

# Kanonická URL aplikace (produkce: https://appintegraf.integraf.cz)
# Bez tohoto může přihlášení na HTTPS/proxy selhat; e-mailové odkazy v kalendáři ji také potřebují
AUTH_URL=""
# Volitelná alternativa k AUTH_URL pro absolutní odkazy (např. e-maily), pokud AUTH_URL nechcete duplikovat
# APP_URL=""

# Volitelně: denní úloha upozornění na končící smlouvy (POST /api/cron/contracts-expiry)
# CRON_SECRET="náhodný-dlouhý-řetězec"

# --- Vytěžení návrhu smlouvy z PDF (nová smlouva → „Návrh z PDF“) ---
# Výchozí: lokální Ollama (zdarma): https://ollama.com
# OLLAMA_BASE_URL="http://127.0.0.1:11434"
# První model = rychlejší (typicky mistral), při chybě se zkusí záloha (výchozí llama3:latest):
# OLLAMA_MODEL="mistral:latest"
# OLLAMA_MODEL_FALLBACK="llama3:latest"
# Jen jeden model (bez zálohy): OLLAMA_MODEL_FALLBACK=""
# Timeout jednoho požadavku k LLM v ms (CPU může dlouho běžet; výchozí 600000 = 10 min):
# LLM_REQUEST_TIMEOUT_MS="600000"
# Ollama na jiném stroji v síti:
# OLLAMA_BASE_URL="http://192.168.8.67:11434"
# Místo Ollama lze použít OpenAI-kompatibilní endpoint (Groq, OpenRouter, Azure…):
# CONTRACT_EXTRACT_OPENAI_COMPAT_URL="https://api.example.com/v1/chat/completions"
# CONTRACT_EXTRACT_OPENAI_COMPAT_KEY=""
# CONTRACT_EXTRACT_OPENAI_COMPAT_MODEL="gpt-4o-mini"
# Vypnutí funkce na serveru: CONTRACT_EXTRACT_DISABLED=1

# --- Vytěžení CV do dotazníku personalistiky (záložka Vyplnit dotazník, Groq API) ---
# Pokud nevyplněno, použijí se stejné proměnné CONTRACT_EXTRACT_* výše.
# PERSONALISTIKA_CV_EXTRACT_OPENAI_COMPAT_URL="https://api.groq.com/openai/v1/chat/completions"
# PERSONALISTIKA_CV_EXTRACT_OPENAI_COMPAT_KEY="gsk_..."
# PERSONALISTIKA_CV_EXTRACT_OPENAI_COMPAT_MODEL="llama-3.3-70b-versatile"
# Záloha při výpadku Groq (tokeny, limit…) – automaticky bez dotazu uživatele:
# Klíč z https://aistudio.google.com/apikey
# PERSONALISTIKA_CV_EXTRACT_FALLBACK_OPENAI_COMPAT_KEY="AIza..."
# PERSONALISTIKA_CV_EXTRACT_FALLBACK_OPENAI_COMPAT_URL="https://generativelanguage.googleapis.com/v1beta/openai/chat/completions"
# PERSONALISTIKA_CV_EXTRACT_FALLBACK_OPENAI_COMPAT_MODEL="gemini-2.0-flash"
# PERSONALISTIKA_CV_EXTRACT_DISABLED=1

# --- Vizitka (detail kontaktu): logo /vizitka-integraf-logo.png — absolutní URL z Host hlavičky,
# jinak AUTH_URL nebo APP_URL (pro e-mailový podpis mimo otevřenou stránku).
